# Supabase (shared mmf-agents project)
NEXT_PUBLIC_SUPABASE_URL=https://mdefkqaawrusoaojstpq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT signing secret (Supabase Dashboard → Settings → API → JWT Secret).
# Used by middleware to VERIFY access-token signatures locally. Without it the
# app still runs but tokens are decoded WITHOUT signature verification, leaving
# an authentication-bypass risk. Set this in every deployment.
SUPABASE_JWT_SECRET=

# Anthropic (for any Claude features)
ANTHROPIC_API_KEY=

# Replicate (for AI artwork generation)
REPLICATE_API_TOKEN=

# App Auth - password gate for all users
MIXFOLIO_PASSWORD=
# A random secret string — used to sign session cookies
SESSION_SECRET=

# Email (optional, for notifications)
SENDER_EMAIL=
SENDER_APP_PASSWORD=

# Runway (for AI video generation)
RUNWAY_API_KEY=

# Stripe (billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_STUDIO_PRICE_ID=price_...

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://8cf205f8b18df9fb0bc1206a5be06865@o4511332445323264.ingest.us.sentry.io/4511332458627072
SENTRY_AUTH_TOKEN=
SENTRY_ORG=moodmixformat
SENTRY_PROJECT=mixbase

# Infra control panel (/api/infra/* — powers the macOS architecture diagram)
# Railway GraphQL API token (account or team token) — create at railway.app -> Account -> Tokens.
# Optional: without it, /api/infra/railway still reports app liveness via /api/health.
RAILWAY_API_TOKEN=
# Railway project to query (defaults to the moodmixformat project id).
RAILWAY_PROJECT_ID=9ff29ad4-39cd-45d5-a0e9-5cbd4ffa2227
# Optional overrides for the environment health probes (defaults shown).
RAILWAY_PROD_URL=https://mixbase-production.up.railway.app
RAILWAY_STAGING_URL=https://mixbase-staging.up.railway.app
# Optional reference quotas for Supabase scaling signals (defaults: free-tier 1GB storage / 0.5GB db).
SUPABASE_STORAGE_LIMIT_BYTES=
SUPABASE_DB_LIMIT_BYTES=
# GitHub Actions CI node: repo is public so this works token-free; a token only
# raises the API rate limit. GITHUB_REPO defaults to mgold215/mixbase.
GITHUB_TOKEN=
GITHUB_REPO=mgold215/mixbase
# Sentry node reuses SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT (above).
# Stripe node reuses STRIPE_SECRET_KEY (above) for active-subscription counts.
# SUPABASE_MANAGEMENT_TOKEN (already used by /api/db-init) also unlocks DB size,
# per-bucket bytes, migrations list, and the read-only SQL tool in /api/infra/chat.
